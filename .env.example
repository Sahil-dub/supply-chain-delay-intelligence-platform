# Application
APP_NAME="Supply Chain Delay Intelligence Platform"
APP_ENV=local
LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=supply_chain_delay
POSTGRES_USER=supply_chain_user
POSTGRES_PASSWORD=supply_chain_password

# SQLAlchemy connection string used by ETL scripts and FastAPI services
DATABASE_URL=postgresql+psycopg2://supply_chain_user:supply_chain_password@localhost:5432/supply_chain_delay

# Data paths
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
SAMPLE_DATA_DIR=data/sample

